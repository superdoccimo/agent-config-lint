{
  "required_files": ["HEARTBEAT.md", "AGENTS.md", "SOUL.md", "TODO.md", "USER.md"],
  "required_files_severity": "error",
  "checks": {
    "heartbeat_over_ack": {
      "enabled": true,
      "must_contain_if_has": {
        "has": "HEARTBEAT_OK",
        "must_contain": "毎回必ず何かを進める"
      },
      "severity": "warning",
      "warning": "heartbeat may over-ack and skip useful work"
    },
    "todo_active_task": {
      "enabled": true,
      "must_contain": "- [ ]",
      "severity": "warning",
      "warning": "TODO has no active tasks"
    },
    "todo_contradiction": {
      "enabled": true,
      "severity": "warning",
      "warning": "TODO may contain contradictory task states across sections"
    },
    "file_contains": [
      {
        "enabled": true,
        "file": "HEARTBEAT.md",
        "must_contain": "HEARTBEAT_OK で終わらせない",
        "severity": "error",
        "message": "HEARTBEAT policy missing: must avoid empty ack-only loops"
      },
      {
        "enabled": true,
        "file": "AGENTS.md",
        "must_contain": "Read `SOUL.md`",
        "severity": "warning",
        "message": "AGENTS should define identity-loading step (SOUL.md)"
      }
    ]
  }
}
